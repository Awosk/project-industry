# =====================================================
# Project Oil — Ana Dizin .htaccess
# =====================================================

# .env dosyasını web'den koru
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# .env yedek / örnek dosyaları da koru
<Files ".env_example">
    Order allow,deny
    Deny from all
</Files>

# version.php ve config klasörüne doğrudan erişimi engelle
<FilesMatch "^(version\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Dizin listelemeyi kapat
Options -Indexes

# CSP Engelini Aşmak İçin Gerekli Header Ayarları
<IfModule mod_headers.c>
    Header set Content-Security-Policy "default-src * 'self' 'unsafe-inline' 'unsafe-eval' data: gap: content:; script-src * 'self' 'unsafe-inline' 'unsafe-eval'; style-src * 'self' 'unsafe-inline'; img-src * 'self' data: content:; connect-src * 'self';"
</IfModule>
